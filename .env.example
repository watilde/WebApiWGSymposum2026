# =============================================================================
# Atlas V3 Hackathon Boilerplate — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env
#
# All variables have sensible defaults in docker-compose.yml, so .env is
# optional for a quick local start.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=ohdsi
POSTGRES_PASSWORD=ohdsi
POSTGRES_DB=ohdsi
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# OHDSI WebAPI
# ---------------------------------------------------------------------------
# Port exposed on the host for the WebAPI REST endpoint
WEBAPI_PORT=8080

# Schema used by WebAPI / Flyway migrations
OHDSI_SCHEMA=ohdsi

# ---------------------------------------------------------------------------
# OHDSI Atlas (browser UI)
# ---------------------------------------------------------------------------
# Port exposed on the host for the Atlas web UI
ATLAS_PORT=8088

# URL the *browser* uses to reach WebAPI (must be reachable from the host)
WEBAPI_URL=http://localhost:8080/WebAPI/

# Display name shown in the Atlas header
ATLAS_INSTANCE_NAME=OHDSI Hackathon

# ---------------------------------------------------------------------------
# Application (Vite dev servers)
# ---------------------------------------------------------------------------
# Set to "true" to use MSW mock mode (no real API server needed)
# Set to "false" to connect to the Docker WebAPI instance
VITE_MOCK_MODE=true

# WebAPI base URL used by the Vite apps when VITE_MOCK_MODE=false
VITE_WEBAPI_BASE_URL=http://localhost:8080/WebAPI
